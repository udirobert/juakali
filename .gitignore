# ============================================
# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files
# ============================================

# ============================================
# Dependencies
# ============================================
node_modules/

# ============================================
# Build outputs
# ============================================
dist/
build/
.webpack/
.next/
.expo/
web-build/

# Turbo
.turbo/

# ============================================
# Environment files (keep .env.example)
# ============================================
.env
.env.local
.env.*.local
.env.production.local

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo
*.tsbuildinfo/

# ============================================
# Lock files (use pnpm/yarn workspaces)
# ============================================
package-lock.json
yarn.lock
pnpm-lock.yaml
*.lockb

# ============================================
# Native / Mobile
# ============================================
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.hprof
*.trace

# Android
android/.gradle/
android/app/build/
android/build/
android/captures/

# iOS
ios/Pods/
ios/build/
ios/*.xcworkspace
ios/*.xcodeproj

# Expo
.expo/
.expo-shared/

# Metro
.metro-health-check*
.metro-*

# ============================================
# Debug
# ============================================
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
*.log.*

# ============================================
# macOS
# ============================================
.DS_Store
*.pem
.AppleDouble
.LSOverride

# ============================================
# IDE / Editor
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ============================================
# Filesystem recovery
# ============================================
lost+found/
.fseventsd
.Trashes
.Spotlight-V100

# ============================================
# Blackbox CLI (local tooling)
# ============================================
.blackboxcli/

# ============================================
# Gitleaks (allowlist is committed, but logs aren't)
# ============================================
.gitleaks.log

# ============================================
# Qoder (local tooling)
# ============================================
.qoder/settings.local.json

# ============================================
# Plans / Notes (optional - uncomment if needed)
# ============================================
# plans/

# ============================================
# Convex (generated - uncomment if using)
# ============================================
# packages/backend/convex/_generated/
