{
    "compilerOptions": {
        "moduleResolution": "bundler",
        "strict": true,
        "allowJs": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "baseUrl": ".",
        "paths": {
            "@/convex/*": ["./convex/*"]
        },
        "jsx": "react-jsx",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "target": "ESNext",
        "lib": ["ES2021", "dom"],
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "isolatedModules": true,
        "noEmit": true
    },
    "include": ["convex/**/*"],
    "exclude": ["node_modules", "convex/_generated"]
}
