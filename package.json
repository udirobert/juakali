{
    "name": "bloom-monorepo-template",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo run dev",
        "dev:backend": "turbo run dev --filter=@bloom/backend",
        "dev:mobile": "turbo run dev --filter=@bloom/mobile",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "gitleaks": "gitleaks detect --source . --verbose",
        "prepare": "husky"
    },
    "devDependencies": {
        "turbo": "^2.0.12",
        "husky": "^9.0.0"
    },
    "packageManager": "bun@1.3.6"
}
