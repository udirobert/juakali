# ============================================
# Convex Configuration
# ============================================
# Run `npx convex dev` in packages/backend to get these values locally
# For production, set via: bunx convex env set VAR_NAME value

CONVEX_DEPLOYMENT=prod:zealous-corgi-669

# Frontend URLs (used by both apps)
EXPO_PUBLIC_CONVEX_URL=https://zealous-corgi-669.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://zealous-corgi-669.convex.site

# ============================================
# Google Gemini API
# ============================================
# Get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ============================================
# Agent Service
# ============================================
# Agent service URL (used by frontend agent chat)
EXPO_PUBLIC_AGENT_URL=http://localhost:8080

# Agent service -> Convex backend URL
CONVEX_SITE_URL=https://zealous-corgi-669.convex.site

# ============================================
# MCP Server
# ============================================
JUAKALI_BACKEND_URL=https://zealous-corgi-669.convex.site

# ============================================
# Twilio (optional - for SMS/voice production)
# ============================================
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ============================================
# Africa's Talking (optional - for SMS/voice production)
# ============================================
# AFRICAS_TALKING_USERNAME=
# AFRICAS_TALKING_API_KEY=
# AFRICAS_TALKING_SENDER_ID=
