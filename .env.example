# Convex Configuration
# Run `npx convex dev` in packages/backend to get these values

CONVEX_DEPLOYMENT=

# Frontend URLs (used by both apps)
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_SITE_URL=

# Google Gemini API (used by voice processing + agent service)
# Get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Agent service URL (used by frontend agent chat)
EXPO_PUBLIC_AGENT_URL=http://localhost:8080

# Agent service -> Convex backend URL
CONVEX_SITE_URL=http://localhost:3210

# MCP server -> backend URL
JUAKALI_BACKEND_URL=http://localhost:3210
